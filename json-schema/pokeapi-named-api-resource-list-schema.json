{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/pokeapi/refs/heads/main/json-schema/pokeapi-named-api-resource-list-schema.json",
  "title": "NamedAPIResourceList",
  "description": "Pok\u00e9API NamedAPIResourceList schema.",
  "type": "object",
  "properties": {
    "count": {
      "type": "integer"
    },
    "next": {
      "type": "string",
      "nullable": true,
      "format": "uri"
    },
    "previous": {
      "type": "string",
      "nullable": true,
      "format": "uri"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Slug name of the referenced resource."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Canonical URL of the referenced resource."
          }
        }
      }
    }
  }
}